---
import type { HTMLAttributes } from 'astro/types';

type Variant = 'primary' | 'secondary' | 'ghost';
type Size = 'sm' | 'md' | 'lg';

interface CommonProps {
  variant?: Variant;
  size?: Size;
  class?: string;
  disabled?: boolean;
}

type ButtonProps = CommonProps &
  Omit<HTMLAttributes<'button'>, 'class' | 'disabled' | 'size'> & {
    href?: never;
  };

type LinkProps = CommonProps &
  Omit<HTMLAttributes<'a'>, 'class' | 'href'> & {
    href: string;
  };

type Props = ButtonProps | LinkProps;

const {
  variant = 'primary',
  size = 'md',
  class: className,
  disabled = false,
  href,
  ...attributes
} = Astro.props;

const isLink = typeof href === 'string';
const buttonType =
  !isLink && 'type' in attributes
    ? (attributes.type as HTMLAttributes<'button'>['type'])
    : 'button';
const classes = ['button', `button--${variant}`, `button--${size}`, className];
---

{
  isLink ? (
    <a
      {...attributes}
      href={disabled ? undefined : href}
      class:list={classes}
      aria-disabled={disabled ? 'true' : undefined}
      data-disabled={disabled ? '' : undefined}
      tabindex={disabled ? -1 : attributes.tabindex}
    >
      <slot />
    </a>
  ) : (
    <button
      {...attributes}
      type={buttonType}
      class:list={classes}
      disabled={disabled}
    >
      <slot />
    </button>
  )
}

<style>
  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    font-family: var(--font-heading);
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.01em;
    text-align: center;
    text-decoration: none;
    white-space: nowrap;
    cursor: pointer;
    transition:
      background-color 180ms ease,
      border-color 180ms ease,
      color 180ms ease,
      transform 180ms ease;
  }

  .button:hover:not(:disabled, [data-disabled]) {
    text-decoration: none;
  }

  .button:active:not(:disabled, [data-disabled]) {
    transform: translateY(1px);
  }

  .button:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 3px;
  }

  .button:disabled,
  .button[data-disabled] {
    cursor: not-allowed;
    opacity: 0.5;
  }

  .button--primary {
    background-color: var(--color-vamo-red);
    color: var(--color-white);
  }

  .button--primary:hover:not(:disabled, [data-disabled]) {
    background-color: var(--color-primary-hover);
  }

  .button--secondary {
    background-color: var(--color-vamo-black);
    color: var(--color-white);
  }

  .button--secondary:hover:not(:disabled, [data-disabled]) {
    background-color: var(--color-neutral-800);
  }

  .button--ghost {
    border-color: var(--color-border-strong);
    background-color: transparent;
    color: var(--color-text);
  }

  .button--ghost:hover:not(:disabled, [data-disabled]) {
    border-color: var(--color-vamo-black);
    background-color: var(--color-surface);
  }

  .button--sm {
    min-block-size: 2.75rem;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    font-size: 0.875rem;
  }

  .button--md {
    min-block-size: 3rem;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    font-size: 0.9375rem;
  }

  .button--lg {
    min-block-size: 3.5rem;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-8);
    font-size: 1rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .button {
      transition: none;
    }
  }
</style>
